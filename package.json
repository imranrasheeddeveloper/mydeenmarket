{
  "name": "mydeenmarket",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "mkdir -p .next/standalone/.next && rm -rf .next/standalone/.next/static && cp -R .next/static .next/standalone/.next/static && node .next/standalone/server.js",
    "lint": "eslint",
    "db:migrate": "npx prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:clear:products": "tsx prisma/clear-products.ts",
    "db:import:products": "tsx prisma/import-products.ts",
    "db:update:stock-features": "tsx prisma/set-stock-and-features.ts",
    "db:reset": "npx prisma migrate reset",
    "db:reset:force": "npx prisma migrate reset --force",
    "db:studio": "npx prisma studio",
    "backup:prod": "./scripts/backup-prod-to-local.sh",
    "restore:local": "./scripts/restore-local-from-backup.sh",
    "db:scrape:darussalam": "tsx prisma/scrape-darussalam.ts",
    "db:scrape:darussalam:import": "tsx prisma/scrape-darussalam.ts --import",
    "db:download:images": "tsx prisma/download-product-images.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/core": "^0.41.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/pm": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "bcryptjs": "^3.0.3",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "nodemailer": "^7.0.13",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
